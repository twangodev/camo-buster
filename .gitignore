.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# Build output
# NOTE: Do NOT ignore dist/ — JavaScript GitHub Actions require dist/ to be
# committed so the runner can execute the action without a build step.
build/
out/
lib/
*.tsbuildinfo

# Test / coverage
coverage/
.nyc_output/
*.lcov

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Env / secrets
.env
.env.*
!.env.example
*.pem
*.key

# Caches
.cache/
.eslintcache
.parcel-cache
.turbo
.vite

# IDE / editors
.idea/
*.iml
.vscode/
!.vscode/extensions.json
*.swp
*.swo
.project
.classpath
.settings/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Python (in case of helper scripts)
